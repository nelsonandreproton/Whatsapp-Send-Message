# Chave usada pelas aplicações OutSystems para autenticar neste servidor
MIDDLEWARE_API_KEY=muda_esta_chave_middleware_secreta

# Chave interna da Evolution API (não exposta ao OutSystems)
EVOLUTION_API_KEY=muda_esta_chave_evolution_secreta

# Nome da instância criada na Evolution API
EVOLUTION_INSTANCE=aniversarios
